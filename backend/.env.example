AZURE_OPENAI_API_KEY=
# Classic: https://YOUR_RESOURCE.openai.azure.com/
# Foundry: https://YOUR_PROJECT.services.ai.azure.com/
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2024-10-21
# Exact deployment names from Azure portal (Deployments / Models + endpoints)
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=
AZURE_OPENAI_CHAT_DEPLOYMENT=
DATABASE_URL=postgresql://postgres:password@localhost:5432/cattitude
# Comma-separated browser origins allowed to call the API (no spaces, or JSON list)
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

  "electrical": {
    "section_id": "electrical",
    "version": "v4.36",
    "provenance_map": [
      {
        "id": "S1",
        "sentence": "On Supernova, battery banks are combined and isolated automatically, and DC distribution is protected before power reaches the boat's switched circuits.",
        "sources": [
          "vessel.display_name",
          "graph.section:electrical"
        ],
        "kind": "composed_inference",
        "block": "capability_summary",
        "composed_inference": true,
        "contributing_facts": [
          "vessel.display_name",
          "section.electrical owns ACR/Class-T/distribution"
        ]
      },
      {
        "id": "S2",
        "sentence": "The house battery bank is protected by three high-current Class-T fuses (Blue Sea Class T) in the Engine / Machinery Space – Engine Bay — fuses that protect the cables carrying power from the bank if a major electrical fault occurs.",
        "sources": [
          "graph.device:class_t_1",
          "graph.device:class_t_2",
          "graph.device:class_t_3",
          "profile.class_t.device.model",
          "profile.class_t.safety_role.is_protective_device",
          "equipment.class_t_1.places"
        ],
        "kind": "composed_inference",
        "block": "capability_summary",
        "composed_inference": true,
        "contributing_facts": [
          "equipment.class_t.quantity=3",
          "profile.class_t.safety_role.is_protective_device=true",
          "profile.class_t.device.model",
          "equipment.class_t_1.places"
        ]
      },
      {
        "id": "S3",
        "sentence": "An automatic charging relay (Blue Sea Systems Automatic Charging Relays (ACR)) in the Engine / Machinery Space – Engine Bay combines and isolates battery banks based on charging voltage.",
        "sources": [
          "graph.device:blue_sea_acr",
          "profile.blue_sea_acr.device.model",
          "profile.blue_sea_acr.control_surfaces",
          "profile.blue_sea_acr.operator_actions",
          "equipment.blue_sea_acr.places"
        ],
        "kind": "sourced",
        "block": "capability_summary"
      },
      {
        "id": "S4",
        "sentence": "A local rotary isolation switch provides a separate disconnect for its battery connection.",
        "sources": [
          "graph.device:plain_battery_switch",

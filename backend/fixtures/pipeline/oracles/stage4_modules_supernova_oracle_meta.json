          "profile.mli_ultra.evidence:BMS_disconnect_reset"
        ],
        "provenance_metadata": [
          "path_device:masterbus_bridge_interface"
        ]
      },
      {
        "id": "S8",
        "sentence": "Battery isolation switches and Class-T protection for the bank can be found in the Electrical Panel section of this guide.",
        "sources": [

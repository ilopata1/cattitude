{
  "homeRuleSections": [
    {
      "title": "⛔ Never Do This",
      "tone": "danger",
      "rules": [
        {
          "icon": "🚽",
          "tone": "danger",
          "text": "Never put ANYTHING in the toilet except human waste — no toilet paper, no wipes, no paper towels. Paper goes in the bin."
        },
        {
          "icon": "⚓",
          "tone": "danger",
          "text": "Never anchor on coral — always find sand. Coral damage is your liability"
        },
        {
          "icon": "🛞",
          "tone": "danger",
          "text": "Never leave helm unattended with autopilot on in traffic, channels, or near shore"
        }
      ]
    },
    {
      "title": "⚠️ Always Do This",
      "tone": "caution",
      "rules": [
        {
          "icon": "📻",
          "tone": "caution",
          "text": "Always monitor VHF Ch 16 underway — call Cruise Abaco on Ch 09 during office hours (approx 9am–5pm)"
        },
        {
          "icon": "🛟",
          "tone": "caution",
          "text": "Run the Safety Briefing with all guests before every departure",
          "link": "/tabs/do/checklist/safety-brief"
        },
        {
          "icon": "🔋",
          "tone": "caution",
          "text": "Keep battery state above 80% — run engines or generator if solar isn't keeping up"
        }
      ]
    },
    {
      "title": "✅ Good Habits",
      "tone": "good",
      "rules": [
        {
          "icon": "🧊",
          "tone": "good",
          "text": "Minimise fridge/freezer door openings — it's your biggest continuous power draw"
        }
      ]
    }
  ],
